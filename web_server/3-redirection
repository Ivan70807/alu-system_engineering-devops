#!/usr/bin/env bash
# Configures Nginx so that /redirect_me returns a 301 redirect

# Install nginx if not already installed
apt-get update -y
apt-get install -y nginx

CONFIG_FILE="/etc/nginx/sites-available/default"

# Back up the original config once
cp -n "$CONFIG_FILE" "${CONFIG_FILE}.orig"

# Write a complete, known-good default server config
cat > "$CONFIG_FILE" <<'EOF'
server {
	listen 80 default_server;
	listen [::]:80 default_server;

	root /var/www/html;
	index index.html index.htm index.nginx-debian.html;

	server_name _;

	location ~ ^/redirect_me/?$ {
		return 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;
	}

	location / {
		try_files $uri $uri/ =404;
	}
}
EOF

# Validate config before restarting
nginx -t

# Start (or restart) nginx
service nginx start || service nginx restart
service nginx restart

exit 0
